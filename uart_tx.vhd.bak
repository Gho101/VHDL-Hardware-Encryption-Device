library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity uart_tx is
    port (
        clk     : in  std_logic;  -- 50 MHz
        tx      : out std_logic
    );
end uart_tx;

architecture behavioral of uart_tx is

    constant BAUD_RATE : integer := 9600;
    constant CLOCK_FREQ : integer := 50000000;
    constant BAUD_TICK : integer := CLOCK_FREQ / BAUD_RATE;

    signal counter : integer := 0;
    signal bit_index : integer := 0;
    signal shift_reg : std_logic_vector(9 downto 0) := (others => '1');
    signal sending : std_logic := '0';

begin

    process(clk)
    begin
        if rising_edge(clk) then

            if sending = '0' then
                -- Load frame: start bit (0), 'A' (0x41), stop bit (1)
                shift_reg <= '1' & "01000001" & '0';
                bit_index <= 0;
                sending <= '1';
                counter <= 0;

            else
                if counter = BAUD_TICK then
                    counter <= 0;
                    tx <= shift_reg(bit_index);

                    if bit_index = 9 then
                        sending <= '0';
                    else
                        bit_index <= bit_index + 1;
                    end if;

                else
                    counter <= counter + 1;
                end if;
            end if;

        end if;
    end process;

end behavioral;